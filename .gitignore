# dependencies
node_modules/
frontend/node_modules/
backend/node_modules/
jspm_packages/

# builds
dist/
frontend/dist/
build/
frontend/build/
*.tsbuildinfo

# secrets — keep only .env.example in the repo
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/

# runtime user data — contains real emails, password hashes and personal
# activity, must never be pushed to a public repo. The backend recreates
# these files automatically on first write if they're missing, so removing
# them from git does not break the app. backend/data/movies.json is the
# site's movie catalog (not user data) and stays tracked.
backend/data/users.json
backend/data/comments.json
backend/data/leaderboard.json
backend/data/daily_login.json
backend/data/user_challenges.json
backend/data/watch_history.json
backend/data/xp_history.json
backend/data/views.json
backend/data/achievements.json

# stray atomic-write temp files (backend/store/jsonStore.js cleans these up
# normally, but ignore any leftovers so they never get committed)
backend/data/.*.tmp

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

