# runtime user data — легаси от старой JSON-файловой версии хранилища.
# Пользовательские данные (аккаунты, XP, лидерборд, достижения, челленджи,
# комментарии, прогресс просмотра, ежедневные входы) теперь хранятся в
# MongoDB (см. backend/store/db.js и DEPLOY.md), эти файлы больше не
# читаются и не пишутся сервером. Оставлены в .gitignore на случай, если
# где-то ещё лежат старые копии — чтобы случайно не закоммитить в публичный
# репозиторий email'ы, хеши паролей и личную активность пользователей.
# backend/data/movies.json — это каталог фильмов (не пользовательские данные)
# и остаётся единственным файлом, который сервер всё ещё читает/пишет напрямую.
backend/data/users.json
backend/data/comments.json
backend/data/leaderboard.json
backend/data/daily_login.json
backend/data/user_challenges.json
backend/data/watch_history.json
backend/data/xp_history.json
backend/data/views.json
backend/data/achievements.json

# stray atomic-write temp files (backend/store/jsonStore.js cleans these up
# normally, but ignore any leftovers so they never get committed)
backend/data/.*.tmp

