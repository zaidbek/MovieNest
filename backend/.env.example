# Скопируйте этот файл в backend/.env и задайте свои значения.

# Строка подключения к MongoDB (например, бесплатный кластер MongoDB Atlas).
# БЕЗ этой переменной сервер запустится, но не сможет сохранять пользователей,
# XP, лидерборд, комментарии и прогресс — см. DEPLOY.md, раздел
# "Бесплатная база данных (MongoDB Atlas)" за пошаговой инструкцией.
# Пример: mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/movienest
MONGODB_URI=mongodb+srv://zaid:<db_password>@cluster0.5t1wswf.mongodb.net/?appName=Cluster0

# Порт, на котором запускается API
PORT=5000

# Секрет для подписи JWT-токенов — ОБЯЗАТЕЛЬНО замените на длинную случайную строку!
# Сгенерировать можно командой: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=MovieNestSuperSecretKey2026RenderBackend123456789

# Адрес фронтенда — используется для CORS (в проде укажите ваш домен, например https://movienest.example.com)
CLIENT_ORIGIN=http://localhost:5173

# production — включает secure-cookie (HTTPS-only) и строгую политику CSP
NODE_ENV=development

# Роли пользователей (user / admin / superadmin) хранятся в базе данных
# (MongoDB, коллекция users), а не здесь. Email единственного Super Admin'а
# задан в коде проекта: backend/config/roles.js (SUPER_ADMIN_EMAIL). Он
# автоматически получает роль Super Admin при регистрации/входе и может затем
# назначать/снимать обычных администраторов прямо на сайте, в Admin Panel —
# без изменения кода и без повторной публикации проекта в GitHub.
